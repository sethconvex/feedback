{
  "name": "@convex-dev/feedback",
  "description": "Embeddable feature-request & voting backend as a Convex component.",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/client.ts",
  "types": "./src/client.ts",
  "exports": {
    ".": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./convex.config": {
      "types": "./convex.config.ts",
      "default": "./convex.config.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    }
  },
  "files": [
    "src",
    "convex.config.ts",
    "schema.ts",
    "items.ts",
    "bids.ts",
    "devLogs.ts",
    "notifications.ts",
    "agentKeys.ts",
    "todos.ts",
    "progress.ts",
    "_generated"
  ],
  "peerDependencies": {
    "convex": "^1.35.1"
  },
  "devDependencies": {
    "convex": "^1.35.1"
  }
}
